#!/bin/bash
# shellcheck disable=SC3040
set -euo pipefail
PORT="${TRIM_SERVICE_PORT:-18080}"
APPDEST="${TRIM_APPDEST:-/var/apps/CMCCCloudAlive/target}"
PKGVAR="${TRIM_PKGVAR:-${APPDEST}/../../var}"
PIDFILE="$PKGVAR/uvicorn.pid"
UVICORN_BIN="$APPDEST/src/.venv/bin/uvicorn"
APPDIR="$APPDEST/src"
export CMCC_ALIVE_HOME="$PKGVAR"
export CMCC_WEBUI_ALLOW_LIVE=1

pid_alive() {
  local pid="$1"
  [ -n "$pid" ] && [ -d "/proc/$pid" ]
}

port_pid() {
  ss -tlnp | grep ":$PORT " | sed 's/.*pid=\([0-9]*\),.*/\1/'
}

port_in_use() {
  ss -tlnp | grep -q ":$PORT "
}

case "$1" in
  start)
    cd "$APPDIR"
    if port_in_use; then
      PID=$(port_pid)
      [ -n "$PID" ] && echo "$PID" > "$PIDFILE"
      exit 0
    fi
    PID_OLD=$(cat "$PIDFILE" 2>/dev/null) || true
    if ! pid_alive "$PID_OLD"; then
      nohup "$UVICORN_BIN" cmcc_cloud_alive.webui.app:app \
        --host :: --port "$PORT" \
        --workers 1 --log-level info > "$PKGVAR/uvicorn.log" 2>&1 &
      echo $! > "$PIDFILE"
    fi
    ;;
  stop)
    PID=$(cat "$PIDFILE" 2>/dev/null) || true
    pid_alive "$PID" && kill "$PID" 2>/dev/null || true
    port_in_use && fuser -k "$PORT/tcp" 2>/dev/null || true
    rm -f "$PIDFILE"
    ;;
  status)
    if [ -f "$PIDFILE" ]; then
      PID=$(cat "$PIDFILE" 2>/dev/null) || true
      pid_alive "$PID" && exit 0
    fi
    if port_in_use; then
      PID=$(port_pid)
      [ -n "$PID" ] && echo "$PID" > "$PIDFILE" && exit 0
    fi
    exit 3
    ;;
  reload)
    PID=$(cat "$PIDFILE" 2>/dev/null) || true
    pid_alive "$PID" && kill -HUP "$PID" 2>/dev/null || true
    ;;
esac
