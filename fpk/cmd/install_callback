#!/bin/bash
echo "Installing $TRIM_APPNAME $TRIM_APPVER" > "$TRIM_TEMP_LOGFILE"
cd "$TRIM_APPDEST"

PYTHON_BIN="/var/apps/python312/target/bin/python3"

# Create virtualenv with pip
if [ ! -d src/.venv ]; then
  "$PYTHON_BIN" -c "import venv; venv.create('src/.venv', symlinks=True, with_pip=True)"
fi
. src/.venv/bin/activate

# Install dependencies from bundled wheels (offline-first)
if [ -d wheels ] && ls wheels/*.whl 1>/dev/null 2>&1; then
    pip install --no-index --find-links=wheels -r src/requirements.txt --upgrade
    rm -rf wheels
else
    # Fallback to online install
    pip install -r src/requirements.txt
fi

# Ensure log directory
mkdir -p "$TRIM_PKGVAR"/logs 2>/dev/null || true
echo "Installation complete"
